# --- N8N Configuration ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=UTC

# --- Postgres Configuration ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8npassword
POSTGRES_DB=n8n

# --- AI & LLM (OpenAI) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Vector Database (Chroma) ---
CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION=assistant_memory

# --- User Interface (Telegram) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Google Workspace (Gmail, Sheets, Calendar) ---
# Note: You'll need to create a Google Cloud Project and enable these APIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Specific IDs for the Assistant's tools
EXPENSE_SHEET_ID=your-google-sheet-id-for-expenses
PRIMARY_CALENDAR_ID=primary

# --- Security ---
# Set this to a long random string to encrypt credentials
N8N_ENCRYPTION_KEY=a-very-long-random-string-for-n8n-security-1234
