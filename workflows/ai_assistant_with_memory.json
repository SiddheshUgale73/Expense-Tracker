{
  "name": "AI Assistant with Memory (LangChain + Chroma)",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ]
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "model": "gpt-4o-mini",
        "options": {}
      },
      "id": "openai-chat-model",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        450,
        500
      ],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "openai-embeddings",
      "name": "OpenAI Embeddings",
      "type": "@n8n/n8n-nodes-langchain.embeddingsOpenAi",
      "typeVersion": 1,
      "position": [
        600,
        500
      ],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "collectionName": "assistant_memory",
        "options": {}
      },
      "id": "chroma-vector-store",
      "name": "Chroma Vector Store",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreChroma",
      "typeVersion": 1,
      "position": [
        750,
        500
      ],
      "credentials": {
        "chromaApi": {
          "id": "YOUR_CHROMA_CREDENTIAL_ID",
          "name": "Chroma API"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an AI Personal Assistant. Use your memory to provide contextually relevant responses. Today is {{ $now }}.\n\nWhen a user asks to perform an action (Email, Expense, Meeting, Reminder), use the appropriate tool. Always check your memory for past preferences or details.",
        "options": {
          "systemMessagePrompt": "You are a helpful assistant with memory. Use the retrieved context to improve your answers."
        }
      },
      "id": "ai-agent",
      "name": "AI Agent (Memory)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $node[\"Telegram Trigger\"].json.message.chat.id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {}
      },
      "id": "telegram-response",
      "name": "Telegram Response",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        1000,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot API"
        }
      }
    },
    {
      "parameters": {
        "contextWindow": 5
      },
      "id": "window-buffer-memory",
      "name": "Window Buffer Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryWindowBuffer",
      "typeVersion": 1,
      "position": [
        300,
        500
      ]
    }
  ],
  "connections": {
    "Telegram Trigger": {
      "main": [
        [
          {
            "node": "ai-agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "ai-agent",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI Embeddings": {
      "ai_embedding": [
        [
          {
            "node": "chroma-vector-store",
            "type": "ai_embedding",
            "index": 0
          }
        ]
      ]
    },
    "chroma-vector-store": {
      "ai_vectorStore": [
        [
          {
            "node": "ai-agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "ai-agent": {
      "main": [
        [
          {
            "node": "telegram-response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "window-buffer-memory": {
      "ai_memory": [
        [
          {
            "node": "ai-agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "memory-workflow-v1"
}
