{
  "name": "Gmail Draft and Confirm Workflow",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message",
          "callback_query"
        ]
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "=Should I send this email to {{ $node[\"OpenAI Agent\"].json.message.content.entities.email }}?\n\nSubject: {{ $node[\"OpenAI Agent\"].json.message.content.entities.subject }}\nBody: {{ $node[\"OpenAI Agent\"].json.message.content.entities.body }}",
        "replyMarkup": "inline_keyboard",
        "inlineKeyboard": {
          "rows": [
            {
              "buttons": [
                {
                  "text": "✅ Yes, Send",
                  "callback_data": "confirm_send"
                },
                {
                  "text": "❌ No, Cancel",
                  "callback_data": "cancel_send"
                }
              ]
            }
          ]
        }
      },
      "id": "ask-confirmation",
      "name": "Ask Confirmation",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        800,
        100
      ],
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.callback_query.data }}",
              "value2": "confirm_send"
            }
          ]
        }
      },
      "id": "check-confirmation",
      "name": "If Confirmed",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1050,
        100
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "subject": "={{ $node[\"OpenAI Agent\"].json.message.content.entities.subject }}",
        "message": "={{ $node[\"OpenAI Agent\"].json.message.content.entities.body }}",
        "toList": "={{ $node[\"OpenAI Agent\"].json.message.content.entities.email }}"
      },
      "id": "gmail-send",
      "name": "Gmail Send",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [
        1300,
        50
      ],
      "credentials": {
        "googleGmailOAuth2Api": {
          "id": "YOUR_GMAIL_CREDENTIAL_ID",
          "name": "Gmail OAuth2"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $node[\"Telegram Trigger\"].json.callback_query.message.chat.id }}",
        "text": "✅ Email sent successfully!",
        "additionalFields": {}
      },
      "id": "final-success-response",
      "name": "Success Response",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        1550,
        50
      ],
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot API"
        }
      }
    }
  ],
  "connections": {
    "Ask Confirmation": {
      "main": [
        [
          {
            "node": "If Confirmed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "If Confirmed": {
      "main": [
        [
          {
            "node": "Gmail Send",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gmail Send": {
      "main": [
        [
          {
            "node": "Success Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "gmail-workflow-v1"
}
